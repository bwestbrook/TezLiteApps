# Copy this file to .env and fill in real values. .env is gitignored.
#
# DEPLOY_MNEMONIC is a 24-word BIP39 mnemonic for the Tezos account that
# pays origination fees and ends up as the contract's `admin`. The address
# derived from this mnemonic should match constants.js ADMIN_ADDRESS:
#   tz1Vq5mYKXw1dD9js26An8dXdASuzo3bfE2w
# If you're deploying for the first time, generate a fresh wallet and
# update ADMIN_ADDRESS in src/constants.js to match.
#
# Provide ONE of DEPLOY_MNEMONIC or DEPLOY_SK. Mnemonic is preferred
# because it's the format both Temple and Kukai already export.

DEPLOY_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12 word13 word14 word15 word16 word17 word18 word19 word20 word21 word22 word23 word24"

# Alternative: an edsk-encoded secret key. Leave commented if using mnemonic.
# DEPLOY_SK=edsk...

# Optional: passphrase if the key is encrypted.
# DEPLOY_PASSWORD=
